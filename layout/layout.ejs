<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title ? page.title + ' - ' + config.title : config.title %></title>
  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;700;800&family=Comic+Neue:wght@400;700&family=Nunito:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <div class="cartoon-container">
    <%- partial('partial/header') %>
    
    <main class="cartoon-main">
      <%- body %>
    </main>

    <%- partial('partial/footer') %>
  </div>
</body>
</html>
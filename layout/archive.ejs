<div class="archive-container cartoon-box" style="padding: 30px;">
  <h1 class="archive-title" style="margin-top: 0; margin-bottom: 20px; font-size: 2rem; color: var(--text-color); border-bottom: 4px dashed var(--border-color); padding-bottom: 10px;">
    📚 所有文章归档
  </h1>
  <ul class="archive-list" style="list-style: none; padding: 0; margin: 0;">
    <% page.posts.each(function(post) { %>
      <li class="archive-item cartoon-list-item">
        <div class="archive-date">
          <span class="date-badge">📅 <%= date(post.date, 'YYYY-MM-DD') %></span>
        </div>
        <a class="archive-link" href="<%- url_for(post.path) %>">
          <% if (post.password || post.encrypt) { %>
            🔒 <%= post.title || 'Untitled' %>
          <% } else { %>
            <%= post.title || 'Untitled' %>
          <% } %>
        </a>
      </li>
    <% }) %>
  </ul>
</div>

<%- partial('partial/paginator') %>